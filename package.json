{
  "displayName": "KNX Weather Station",
  "name": "@jendrik/homebridge-knx-weather",
  "type": "module",
  "version": "0.1.0",
  "description": "Homebridge plugin for KNX Weather Stations",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/jendrik/homebridge-knx-weather.git"
  },
  "bugs": {
