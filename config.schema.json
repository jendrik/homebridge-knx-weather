{
  "pluginAlias": "knx-weather",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "ip": {
      "title": "KNX Router or Interface",
      "type": "string",
      "default": "224.0.23.12",
      "placeholder": "224.0.23.12",
      "description": "IP address of the KNX router or interface."
    },
    "port": {
      "title": "KNX Port",
      "type": "number",
      "default": 3671,
      "minimum": 1,
      "maximum": 65535,
      "multipleOf": 1,
      "placeholder": 3671,
      "description": "Port of the KNX router or interface."
    },
    "latitude": {
      "title": "Latitude",
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "required": true,
      "placeholder": 51.790986,
      "description": "Latitude of the location used for solar phase calculation."
    },
    "longitude": {
      "title": "Longitude",
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "required": true,
      "placeholder": 9.436365,
      "description": "Longitude of the location used for solar phase calculation."
    }
  },
  "layout": [
    {
      "type": "section",
      "title": "Global",
      "expandable": true,
      "expanded": false,
      "items": [
        "ip",
        "port",
        "latitude",
        "longitude"
      ]
    }
  ]
}
